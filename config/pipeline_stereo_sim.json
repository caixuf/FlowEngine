{
  "_comment": "仿真双目感知链路验证配置。基于 pipeline.json，将 ground-truth perception 替换为 stereo_vision (双目深度→DBSCAN→障碍物) + traversability (可通行区域)。与 pipeline.json 的区别: (1) sim_world 额外发布 sensor/stereo (光线投射深度图 80×60@10Hz) (2) perception 节点移除,由 stereo_vision 接管 perception/obstacles (3) 新增 traversability 节点发布 perception/traversability。其余节点(planning/control/safety_control/inference 等)不变——它们只消费 perception/obstacles，对来源无感知。",
  "log_file": "launcher.log",
  "log_level": 2,
  "monitor_interval": 5,
  "enable_monitor": true,
  "scheduler": {
    "mode": "choreo",
    "worker_threads": 0,
    "tick_us": 1000
  },
  "processes": [
    {
      "name": "sim_world",
      "library_path": "build/lib/libsim_world.so",
      "auto_start": true,
      "publish": [
        {
          "topic": "vehicle/state",
          "type": "VehicleState",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 50
          }
        },
        {
          "topic": "road/geometry",
          "type": "RoadGeometry",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        },
        {
          "topic": "sensor/stereo",
          "type": "StereoFrame",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 100
          }
        }
      ],
      "params": "{\"init_speed\": 5.0, \"target_speed\": 12.0, \"frequency_hz\": 50.0, \"random_seed\": 42, \"scenario_file\": \"scenarios/pedestrian_crossing.json\", \"stereo_enabled\": 1, \"stereo_fov_deg\": 65.0, \"stereo_v_fov_deg\": 50.0, \"stereo_camera_height_m\": 0.30, \"stereo_camera_tilt_deg\": 10.0}"
    },
    {
      "name": "sensor_model",
      "library_path": "build/lib/libsensor_model.so",
      "auto_start": true,
      "subscribe": [
        "vehicle/state"
      ],
      "publish": [
        {
          "topic": "sensor/lidar",
          "type": "LidarFrame",
          "qos": {
            "depth": 2,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 50
          }
        },
        {
          "topic": "sensor/gps",
          "type": "GpsFrame",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 100
          }
        },
        {
          "topic": "sensor/camera",
          "type": "CameraFrame",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        }
      ],
      "params": "{\"lidar_rate_hz\":20,\"lidar_fov_deg\":120.0,\"lidar_max_range_m\":60.0,\"obs_noise_std_m\":0.08,\"enable_simple_occlusion\":1}"
    },
    {
      "_comment": "双目视觉感知: 订阅 sensor/stereo → 深度反投影 → DBSCAN 聚类 → perception/obstacles。替代 pipeline.json 中基于 vehicle/state 真值的 perception 节点。",
      "name": "stereo_vision",
      "library_path": "build/lib/libstereo_vision_node.so",
      "auto_start": true,
      "subscribe": [
        "sensor/stereo"
      ],
      "publish": [
        {
          "topic": "perception/obstacles",
          "type": "ObstacleList",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 100
          }
        }
      ],
      "params": "{\"enable\":1,\"min_range\":0.5,\"max_range\":8.0,\"stride\":2,\"dbscan_eps\":0.4,\"dbscan_min_pts\":6,\"min_cluster_size\":8.0,\"output_topic\":\"perception/obstacles\"}"
    },
    {
      "_comment": "可通行区域检测: 订阅 sensor/stereo → 3D 反投影 → 地面分割 → 占用栅格 → 走廊提取 → perception/traversability (JSON text)。",
      "name": "traversability",
      "library_path": "build/lib/libtraversability_node.so",
      "auto_start": true,
      "subscribe": [
        "sensor/stereo"
      ],
      "publish": [
        {
          "topic": "perception/traversability",
          "type": "text",
          "qos": { "depth": 1, "policy": "drop_oldest", "reliability": "best_effort" }
        }
      ],
      "params": "{\"enable\":1,\"min_range\":0.5,\"max_range\":6.0,\"stride\":2,\"camera_height_m\":0.30,\"camera_tilt_deg\":10.0,\"ground_tol_m\":0.08,\"obstacle_height_m\":0.10,\"cell_size_m\":0.20,\"x_range_m\":6.0,\"y_range_m\":3.0,\"v_fov_deg\":50.0,\"min_corridor_width_m\":0.6,\"publish_hz\":10,\"output_topic\":\"perception/traversability\"}"
    },
    {
      "name": "fusion",
      "library_path": "build/lib/libfusion_node.so",
      "auto_start": true,
      "subscribe": [
        "sensor/lidar",
        "sensor/gps"
      ],
      "publish": [
        {
          "topic": "fusion/localization",
          "type": "Localization",
          "qos": {
            "depth": 1
          }
        },
        {
          "topic": "fusion/latency",
          "type": "LatencyReport"
        }
      ],
      "params": "{\"frequency_hz\":20.0}"
    },
    {
      "name": "planning",
      "library_path": "build/lib/libplanning_node.so",
      "auto_start": true,
      "subscribe": [
        "fusion/localization",
        "vehicle/state",
        "road/geometry"
      ],
      "publish": [
        {
          "topic": "planning/trajectory",
          "type": "Trajectory",
          "qos": {
            "depth": 1
          }
        }
      ],
      "params": "{\"target_speed\": 12.0, \"max_speed\": 20.0, \"max_accel\": 4.0, \"ref_path_length_m\": 5000.0, \"highway_speed_mps\": 10.0, \"scenario_file\": \"scenarios/pedestrian_crossing.json\"}"
    },
    {
      "name": "control",
      "library_path": "build/lib/libcontrol_node.so",
      "auto_start": true,
      "subscribe": [
        "fusion/localization",
        "planning/trajectory",
        "vehicle/state",
        "road/geometry"
      ],
      "publish": [
        {
          "topic": "control/raw_cmd",
          "type": "ControlRaw",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 100
          }
        }
      ],
      "params": "{\"pid_kp\": 800.0, \"pid_ki\": 50.0, \"pid_kd\": 100.0, \"target_speed\": 12.0, \"lat_kp\": 0.5, \"lat_kd_heading\": 1.35, \"yaw_damping\": 0.15, \"lane_change_blocked_timeout_s\": 0.6, \"lc_stable_wait_s\": 4.0, \"lc_cooldown_after_stable_s\": 1.5, \"lc_cooldown_after_return_s\": 2.0, \"min_overtake_gap_base\": 14.0, \"min_overtake_gap_cap\": 90.0, \"min_overtake_gap_speed_mult\": 0.7, \"steer_min_clamp\": 0.016, \"scenario_file\": \"scenarios/pedestrian_crossing.json\"}"
    },
    {
      "name": "safety_control",
      "library_path": "build/lib/libsafety_control_node.so",
      "auto_start": true,
      "subscribe": [
        "control/raw_cmd",
        "vehicle/state"
      ],
      "publish": [
        {
          "topic": "control/cmd",
          "type": "ControlCmd",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 50
          }
        }
      ],
      "params": "{\"max_throttle\":1.0,\"max_steer\":0.22,\"low_speed_steer\":0.18,\"time_headway\":1.3}"
    },
    {
      "name": "inference",
      "library_path": "build/lib/libinference_node.so",
      "auto_start": true,
      "subscribe": [
        "control/cmd",
        "fusion/localization",
        "perception/obstacles",
        "planning/trajectory"
      ],
      "publish": [
        {
          "topic": "inference/trajectory",
          "type": "Trajectory",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        }
      ],
      "params": "{\"max_speed\":20.0,\"frequency_hz\":20.0,\"model_path\":\"tools/train/model.txt\",\"control_mode\":\"shadow\"}"
    },
    {
      "name": "data_recorder",
      "library_path": "build/lib/libdata_recorder_node.so",
      "auto_start": true,
      "subscribe": [
        "fusion/localization",
        "planning/trajectory",
        "perception/obstacles",
        "control/cmd"
      ],
      "params": "{\"frequency_hz\":20.0,\"output_path\":\"/tmp/flow_train_samples.jsonl\"}"
    },
    {
      "name": "monitor",
      "library_path": "build/lib/libmonitor_node.so",
      "auto_start": true,
      "subscribe": [
        "perception/obstacles",
        "perception/traversability",
        "vehicle/state",
        "fusion/latency",
        "flowengine/node_info",
        "planning/trajectory",
        "road/geometry"
      ],
      "params": "{\"state_file\":\"/tmp/flow_topology.json\",\"export_scene\":true}"
    }
  ]
}
