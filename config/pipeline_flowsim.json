{
  "log_file": "launcher.log",
  "log_level": 2,
  "monitor_interval": 5,
  "enable_monitor": true,
  "scheduler": {
    "mode": "choreo",
    "worker_threads": 0,
    "tick_us": 1000
  },
  "processes": [
    {
      "name": "flowsim",
      "library_path": "build/lib/libflowsim_node.so",
      "auto_start": true,
      "subscribe": [
        "control/raw_cmd"
      ],
      "publish": [
        {
          "topic": "vehicle/state",
          "type": "VehicleState",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 50
          }
        },
        {
          "topic": "road/geometry",
          "type": "RoadGeometry",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        },
        {
          "topic": "road/traffic_lights",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        },
        {
          "topic": "scene/frame",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        },
        {
          "topic": "sim/tick",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        }
      ],
      "params": "{\"init_speed\": 5.0, \"target_speed\": 12.0, \"frequency_hz\": 50.0, \"random_seed\": 42, \"scenario_file\": \"scenarios/city_to_highway.json\"}"
    },
    {
      "name": "sensor_model",
      "library_path": "build/lib/libsensor_model.so",
      "auto_start": true,
      "subscribe": [
        "vehicle/state"
      ],
      "publish": [
        {
          "topic": "sensor/lidar",
          "type": "LidarFrame",
          "qos": {
            "depth": 2,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 50
          }
        },
        {
          "topic": "sensor/gps",
          "type": "GpsFrame",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 100
          }
        },
        {
          "topic": "sensor/camera",
          "type": "CameraFrame",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        }
      ],
      "params": "{\"lidar_rate_hz\":20,\"lidar_fov_deg\":120.0,\"lidar_max_range_m\":60.0,\"obs_noise_std_m\":0.08,\"enable_simple_occlusion\":1}"
    },
    {
      "name": "perception",
      "library_path": "build/lib/libperception_node.so",
      "auto_start": true,
      "subscribe": [
        "vehicle/state"
      ],
      "publish": [
        {
          "topic": "perception/obstacles",
          "type": "ObstacleList"
        }
      ],
      "params": "{\"frequency_hz\":10.0}"
    },
    {
      "name": "fusion",
      "library_path": "build/lib/libfusion_node.so",
      "auto_start": true,
      "subscribe": [
        "sensor/lidar",
        "sensor/gps"
      ],
      "publish": [
        {
          "topic": "fusion/localization",
          "type": "Localization",
          "qos": {
            "depth": 1
          }
        },
        {
          "topic": "fusion/latency",
          "type": "LatencyReport"
        }
      ],
      "params": "{\"frequency_hz\":20.0}"
    },
    {
      "name": "planning",
      "library_path": "build/lib/libplanning_node.so",
      "auto_start": true,
      "subscribe": [
        "fusion/localization",
        "vehicle/state",
        "road/geometry",
        "road/traffic_lights"
      ],
      "publish": [
        {
          "topic": "planning/trajectory",
          "type": "Trajectory",
          "qos": {
            "depth": 1
          }
        }
      ],
      "params": "{\"target_speed\": 12.0, \"max_speed\": 20.0, \"max_accel\": 4.0, \"ref_path_length_m\": 5000.0, \"highway_speed_mps\": 10.0, \"scenario_file\": \"scenarios/city_to_highway.json\"}"
    },
    {
      "name": "control",
      "library_path": "build/lib/libcontrol_node.so",
      "auto_start": true,
      "subscribe": [
        "fusion/localization",
        "planning/trajectory",
        "vehicle/state",
        "road/geometry"
      ],
      "publish": [
        {
          "topic": "control/raw_cmd",
          "type": "ControlRaw",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 100
          }
        }
      ],
      "params": "{\"pid_kp\": 800.0, \"pid_ki\": 50.0, \"pid_kd\": 100.0, \"target_speed\": 12.0, \"lat_kp\": 0.5, \"lat_kd_heading\": 1.35, \"yaw_damping\": 0.15, \"lane_change_blocked_timeout_s\": 0.6, \"lc_stable_wait_s\": 4.0, \"lc_cooldown_after_stable_s\": 1.5, \"lc_cooldown_after_return_s\": 2.0, \"min_overtake_gap_base\": 14.0, \"min_overtake_gap_cap\": 90.0, \"min_overtake_gap_speed_mult\": 0.7, \"steer_min_clamp\": 0.016, \"scenario_file\": \"scenarios/city_to_highway.json\"}"
    },
    {
      "name": "safety_control",
      "library_path": "build/lib/libsafety_control_node.so",
      "auto_start": true,
      "subscribe": [
        "control/raw_cmd",
        "vehicle/state"
      ],
      "publish": [
        {
          "topic": "control/cmd",
          "type": "ControlCmd",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 50
          }
        }
      ],
      "params": "{\"max_throttle\":1.0,\"max_steer\":0.22,\"low_speed_steer\":0.18,\"time_headway\":1.3}"
    },
    {
      "name": "monitor",
      "library_path": "build/lib/libmonitor_node.so",
      "auto_start": true,
      "subscribe": [
        "perception/obstacles",
        "vehicle/state",
        "fusion/latency",
        "flowengine/node_info",
        "planning/trajectory",
        "road/geometry",
        "road/traffic_lights",
        "scene/frame"
      ],
      "params": "{\"state_file\":\"/tmp/flow_topology.json\",\"export_scene\":true}"
    }
  ]
}
