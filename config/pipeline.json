{
  "startup_stagger_ms": 150,
  "nodes": [
    {
      "name": "sim_world",
      "library": "build/lib/libsim_world.so",
      "outputs": ["vehicle/state"],
      "params": {
        "init_speed": 5.0,
          "target_speed": 12.0,
        "frequency_hz": 50.0,
        "random_seed": 42,
        "scenario_file": "scenarios/pedestrian_crossing.json"
      }
    },
    {
      "name": "sensor_model",
      "library": "build/lib/libsensor_model.so",
      "inputs": ["vehicle/state"],
      "outputs": ["sensor/lidar", "sensor/gps", "sensor/camera"],
      "params": {
        "lidar_rate_hz": 20,
        "lidar_fov_deg": 120.0,
        "lidar_max_range_m": 60.0,
        "obs_noise_std_m": 0.08,
        "enable_simple_occlusion": 1
      }
    },
    {
      "name": "perception",
      "library": "build/lib/libperception_node.so",
      "inputs": ["vehicle/state", "sensor/lidar"],
      "outputs": ["perception/obstacles"],
      "params": {
        "frequency_hz": 10.0
      }
    },
    {
      "name": "fusion",
      "library": "build/lib/libfusion_node.so",
      "inputs": ["sensor/gps", "perception/obstacles"],
      "outputs": ["fusion/localization", "fusion/latency"],
      "params": {
        "frequency_hz": 20.0
      }
    },
    {
      "name": "planning",
      "library": "build/lib/libplanning_node.so",
      "inputs": ["fusion/localization", "vehicle/state"],
      "outputs": ["planning/trajectory"],
      "params": {
        "target_speed": 12.0,
        "max_speed": 20.0,
        "max_accel": 4.0,
        "ref_path_length_m": 5000.0
      }
    },
    {
      "name": "control",
      "library": "build/lib/libcontrol_node.so",
      "inputs": ["planning/trajectory", "vehicle/state"],
      "outputs": ["control/raw_cmd"],
      "params": {
        "pid_kp": 800.0,
        "pid_ki": 50.0,
        "pid_kd": 100.0,
        "target_speed": 12.0,
        "lat_kp": 0.32,
        "lat_kd_heading": 1.35,
        "lane_change_blocked_timeout_s": 2.0
      }
    },
    {
      "name": "safety_control",
      "library": "build/lib/libsafety_control_node.so",
      "inputs": ["control/raw_cmd", "vehicle/state"],
      "outputs": ["control/cmd"],
      "params": {
        "max_throttle": 1.0,
        "max_steer": 0.22,
        "low_speed_steer": 0.18,
        "time_headway": 1.3
      }
    },
    {
      "name": "monitor",
      "library": "build/lib/libmonitor_node.so",
      "inputs": ["perception/obstacles", "vehicle/state", "fusion/latency"],
      "params": {
        "state_file": "/tmp/flow_topology.json",
        "export_scene": true
      }
    }
  ]
}