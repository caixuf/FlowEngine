{
  "_comment": "真车部署配置模板 (RC 小车 L2: 航点跟随 + 局部避障)。本配置面向 RC 小车场景：用 waypoint_follower 替代 planning，用 actuator_pwm 替代 actuator(CAN)。真车高速场景把 waypoint_follower 换回 planning_node、actuator_pwm 换回 actuator_node 即可。改 params 里的串口/I2C/航点文件路径即可部署。感知融合(perception_fusion)默认关: 同时用 LiDAR+双目时把 lidar_driver.output_topic 改 perception/obstacles_lidar、stereo_vision.output_topic 改 perception/obstacles_stereo、perception_fusion.enable 改 1，两路自动去重合并成 perception/obstacles。可通行区域检测(traversability)默认开: 订阅 sensor/stereo 输出 perception/traversability (前方占用栅格+可通行走廊摘要)，无下游消费者时不影响流水线，monitor/inference 可选订阅。",
  "log_file": "launcher_car.log",
  "log_level": 2,
  "monitor_interval": 5,
  "enable_monitor": true,
  "scheduler": {
    "mode": "choreo",
    "worker_threads": 0,
    "tick_us": 1000
  },
  "processes": [
    {
      "name": "gps_driver",
      "library_path": "build/lib/libgps_driver_node.so",
      "auto_start": true,
      "publish": [
        {
          "topic": "sensor/gps",
          "type": "GpsData",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 100
          }
        }
      ],
      "params": "{\"serial_port\":\"/dev/ttyUSB0\",\"baud_rate\":9600,\"enable\":1,\"publish_hz\":10,\"dry_run\":0}"
    },
    {
      "name": "imu_driver",
      "library_path": "build/lib/libimu_driver_node.so",
      "auto_start": true,
      "publish": [
        {
          "topic": "sensor/imu",
          "type": "ImuData",
          "qos": {
            "depth": 4,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 20
          }
        }
      ],
      "params": "{\"serial_port\":\"/dev/ttyUSB2\",\"baud_rate\":115200,\"enable\":1,\"sample_hz\":100,\"gravity\":9.80665,\"dry_run\":0}"
    },
    {
      "name": "slam",
      "library_path": "build/lib/libslam_node.so",
      "auto_start": true,
      "subscribe": [
        "sensor/lidar",
        "sensor/imu"
      ],
      "publish": [
        {
          "topic": "sensor/pose",
          "type": "Pose2D",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 50
          }
        }
      ],
      "params": "{\"enable\":1,\"publish_hz\":20,\"dry_run\":0,\"use_lidar\":1,\"use_imu\":1,\"algo\":\"dead_reckon\",\"initial_x\":0.0,\"initial_y\":0.0,\"initial_heading\":0.0}"
    },
    {
      "name": "stereo_camera",
      "library_path": "build/lib/libstereo_camera_node.so",
      "auto_start": true,
      "publish": [
        {
          "topic": "sensor/stereo",
          "type": "StereoFrame",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 200
          }
        }
      ],
      "params": "{\"fps\":10,\"width\":320,\"height\":240,\"baseline_m\":0.075,\"fov_deg\":65.0,\"jpeg_quality\":70,\"enable\":1,\"dry_run\":0,\"device_id\":\"\"}"
    },
    {
      "name": "lidar_driver",
      "library_path": "build/lib/liblidar_driver_node.so",
      "auto_start": true,
      "publish": [
        {
          "topic": "perception/obstacles",
          "type": "ObstacleList",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 100
          }
        }
      ],
      "params": "{\"serial_port\":\"/dev/ttyUSB1\",\"baud_rate\":115200,\"enable\":0,\"scan_hz\":10,\"dbscan_eps\":2.0,\"dbscan_min_pts\":4,\"ground_z_thresh\":0.15,\"max_points\":2000,\"max_range_m\":60.0,\"output_topic\":\"perception/obstacles\",\"dry_run\":0}"
    },
    {
      "name": "stereo_vision",
      "library_path": "build/lib/libstereo_vision_node.so",
      "auto_start": true,
      "subscribe": [
        "sensor/stereo"
      ],
      "publish": [
        {
          "topic": "perception/obstacles",
          "type": "ObstacleList",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 100
          }
        }
      ],
      "params": "{\"enable\":1,\"min_range\":0.5,\"max_range\":8.0,\"stride\":2,\"dbscan_eps\":0.4,\"dbscan_min_pts\":6,\"ground_z_thresh\":0.1,\"min_cluster_size\":8.0,\"output_topic\":\"perception/obstacles\"}"
    },
    {
      "name": "traversability",
      "library_path": "build/lib/libtraversability_node.so",
      "auto_start": true,
      "subscribe": [
        "sensor/stereo"
      ],
      "publish": [
        {
          "topic": "perception/traversability",
          "type": "text",
          "qos": { "depth": 1, "policy": "drop_oldest", "reliability": "best_effort" }
        }
      ],
      "params": "{\"enable\":1,\"min_range\":0.5,\"max_range\":6.0,\"stride\":2,\"camera_height_m\":0.30,\"camera_tilt_deg\":0.0,\"ground_tol_m\":0.08,\"obstacle_height_m\":0.10,\"cell_size_m\":0.20,\"x_range_m\":6.0,\"y_range_m\":3.0,\"v_fov_deg\":50.0,\"min_corridor_width_m\":0.6,\"publish_hz\":10,\"output_topic\":\"perception/traversability\"}"
    },
    {
      "name": "perception_fusion",
      "library_path": "build/lib/libperception_fusion_node.so",
      "auto_start": true,
      "subscribe": [
        "perception/obstacles_lidar",
        "perception/obstacles_stereo"
      ],
      "publish": [
        {
          "topic": "perception/obstacles",
          "type": "ObstacleList",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 100
          }
        }
      ],
      "params": "{\"enable\":0,\"input_a_topic\":\"perception/obstacles_lidar\",\"input_b_topic\":\"perception/obstacles_stereo\",\"output_topic\":\"perception/obstacles\",\"merge_dist\":1.0,\"publish_hz\":10,\"max_age_ms\":500}"
    },
    {
      "name": "fusion",
      "library_path": "build/lib/libfusion_node.so",
      "auto_start": true,
      "subscribe": [
        "sensor/gps",
        "sensor/pose"
      ],
      "publish": [
        {
          "topic": "fusion/localization",
          "type": "Localization",
          "qos": {
            "depth": 1
          }
        },
        {
          "topic": "fusion/latency",
          "type": "LatencyReport"
        }
      ],
      "params": "{\"frequency_hz\":20.0}"
    },
    {
      "name": "waypoint_follower",
      "library_path": "build/lib/libwaypoint_follower_node.so",
      "auto_start": true,
      "subscribe": [
        "fusion/localization",
        "perception/obstacles"
      ],
      "publish": [
        {
          "topic": "planning/trajectory",
          "type": "Trajectory",
          "qos": {
            "depth": 1
          }
        }
      ],
      "params": "{\"waypoints_file\":\"/tmp/waypoints.json\",\"loop\":1,\"cruise_speed\":2.0,\"lookahead_m\":1.5,\"plan_hz\":10,\"obstacle_slow_dist\":3.0,\"obstacle_stop_dist\":0.8}"
    },
    {
      "name": "control",
      "library_path": "build/lib/libcontrol_node.so",
      "auto_start": true,
      "subscribe": [
        "fusion/localization",
        "planning/trajectory",
        "perception/obstacles"
      ],
      "publish": [
        {
          "topic": "control/raw_cmd",
          "type": "ControlRaw",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 100
          }
        },
        {
          "topic": "control/cte",
          "type": "text",
          "qos": { "depth": 1, "policy": "drop_oldest", "reliability": "best_effort" }
        },
        {
          "topic": "control/ldw",
          "type": "text",
          "qos": { "depth": 1, "policy": "drop_oldest", "reliability": "best_effort" }
        }
      ],
      "params": "{\"pid_kp\": 300.0, \"pid_ki\": 20.0, \"pid_kd\": 40.0, \"target_speed\": 2.0, \"wheelbase\": 0.3, \"lat_kp\": 0.8, \"lat_kd_heading\": 1.35, \"yaw_damping\": 0.15, \"steer_min_clamp\": 0.02, \"ldw_threshold\": 0.3, \"ldw_min_speed\": 0.5, \"ldw_cooldown\": 2.0}"
    },
    {
      "name": "safety_control",
      "library_path": "build/lib/libsafety_control_node.so",
      "auto_start": true,
      "subscribe": [
        "control/raw_cmd",
        "perception/obstacles"
      ],
      "publish": [
        {
          "topic": "control/cmd",
          "type": "ControlCmd",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 50
          }
        }
      ],
      "params": "{\"max_throttle\":0.6,\"max_steer\":0.35,\"low_speed_steer\":0.35,\"time_headway\":1.0}"
    },
    {
      "name": "actuator",
      "library_path": "build/lib/libactuator_pwm_node.so",
      "auto_start": true,
      "subscribe": [
        "control/cmd"
      ],
      "params": "{\"backend\":\"pca9685\",\"i2c_bus\":1,\"i2c_addr\":64,\"esc_channel\":0,\"steer_channel\":1,\"pwm_freq_hz\":50,\"throttle_scale\":500,\"steering_scale\":500,\"gpio_esc_pin\":12,\"gpio_steer_pin\":13,\"watchdog_timeout_s\":3,\"enable\":1,\"dry_run\":0}"
    },
    {
      "name": "inference",
      "library_path": "build/lib/libinference_node.so",
      "auto_start": true,
      "subscribe": [
        "control/cmd",
        "fusion/localization",
        "perception/obstacles",
        "planning/trajectory"
      ],
      "publish": [
        {
          "topic": "inference/trajectory",
          "type": "Trajectory",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        }
      ],
      "params": "{\"max_speed\":15.0,\"frequency_hz\":20.0,\"model_path\":\"tools/train/model.txt\",\"control_mode\":\"shadow\"}"
    },
    {
      "name": "data_recorder",
      "library_path": "build/lib/libdata_recorder_node.so",
      "auto_start": true,
      "subscribe": [
        "fusion/localization",
        "planning/trajectory",
        "perception/obstacles",
        "control/cmd"
      ],
      "params": "{\"frequency_hz\":20.0,\"output_path\":\"/tmp/flow_train_samples.jsonl\"}"
    },
    {
      "name": "learner",
      "library_path": "build/lib/liblearner_node.so",
      "auto_start": true,
      "subscribe": [
        "fusion/localization",
        "planning/trajectory",
        "perception/obstacles",
        "control/cmd"
      ],
      "publish": [
        {
          "topic": "learner/status",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        }
      ],
      "params": "{\"train_hz\":0.5,\"lr\":0.001,\"batch_size\":32,\"buffer_size\":512,\"full_finetune\":0,\"save_interval\":50,\"model_path\":\"tools/train/model.txt\",\"save_path\":\"/tmp/flow_learner_model.txt\"}"
    },
    {
      "name": "model_ota",
      "library_path": "build/lib/libmodel_ota_node.so",
      "auto_start": true,
      "subscribe": [
        "model_ota/cmd",
        "fusion/localization"
      ],
      "publish": [
        { "topic": "model_ota/active", "qos": { "depth": 1, "policy": "drop_oldest", "reliability": "best_effort" } },
        { "topic": "model_ota/status", "qos": { "depth": 1, "policy": "drop_oldest", "reliability": "best_effort" } },
        { "topic": "model_ota/ab_result", "qos": { "depth": 1, "policy": "drop_oldest", "reliability": "best_effort" } }
      ],
      "params": "{\"poll_interval_ms\":500,\"status_hz\":1.0,\"ab_ratio\":0.5,\"runtime_model_path\":\"tools/train/model.txt\",\"registry_path\":\"models/registry.json\"}"
    },
    {
      "name": "monitor",
      "library_path": "build/lib/libmonitor_node.so",
      "auto_start": true,
      "subscribe": [
        "perception/obstacles",
        "fusion/latency",
        "flowengine/node_info",
        "planning/trajectory"
      ],
      "params": "{\"state_file\":\"/tmp/flow_topology.json\",\"export_scene\":true}"
    }
  ]
}
