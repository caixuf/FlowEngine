{
  "_comment": "真车部署配置模板 — 替代 pipeline.json 的仿真配置。去 sim_world/sensor_model/perception，加 lidar_driver/gps_driver/actuator。改 params 里的串口设备/CAN接口即可部署。",
  "log_file": "launcher_car.log",
  "log_level": 2,
  "monitor_interval": 5,
  "enable_monitor": true,
  "scheduler": {
    "mode": "choreo",
    "worker_threads": 0,
    "tick_us": 1000
  },
  "processes": [
    {
      "name": "gps_driver",
      "library_path": "build/lib/libgps_driver_node.so",
      "auto_start": true,
      "publish": [
        {
          "topic": "sensor/gps",
          "type": "GpsData",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 100
          }
        }
      ],
      "params": "{\"serial_port\":\"/dev/ttyUSB0\",\"baud_rate\":9600,\"enable\":1,\"publish_hz\":10,\"dry_run\":0}"
    },
    {
      "name": "imu_driver",
      "library_path": "build/lib/libimu_driver_node.so",
      "auto_start": true,
      "publish": [
        {
          "topic": "sensor/imu",
          "type": "ImuData",
          "qos": {
            "depth": 4,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 20
          }
        }
      ],
      "params": "{\"serial_port\":\"/dev/ttyUSB2\",\"baud_rate\":115200,\"enable\":1,\"sample_hz\":100,\"gravity\":9.80665,\"dry_run\":0}"
    },
    {
      "name": "slam",
      "library_path": "build/lib/libslam_node.so",
      "auto_start": true,
      "subscribe": [
        "sensor/lidar",
        "sensor/imu"
      ],
      "publish": [
        {
          "topic": "sensor/pose",
          "type": "Pose2D",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 50
          }
        }
      ],
      "params": "{\"enable\":1,\"publish_hz\":20,\"dry_run\":0,\"use_lidar\":1,\"use_imu\":1,\"algo\":\"dead_reckon\",\"initial_x\":0.0,\"initial_y\":0.0,\"initial_heading\":0.0}"
    },
    {
      "name": "stereo_camera",
      "library_path": "build/lib/libstereo_camera_node.so",
      "auto_start": true,
      "publish": [
        {
          "topic": "sensor/stereo",
          "type": "StereoFrame",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 200
          }
        }
      ],
      "params": "{\"fps\":10,\"width\":320,\"height\":240,\"baseline_m\":0.075,\"fov_deg\":65.0,\"jpeg_quality\":70,\"enable\":1,\"dry_run\":0,\"device_id\":\"\"}"
    },
    {
      "name": "lidar_driver",
      "library_path": "build/lib/liblidar_driver_node.so",
      "auto_start": true,
      "publish": [
        {
          "topic": "perception/obstacles",
          "type": "ObstacleList",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 100
          }
        }
      ],
      "params": "{\"serial_port\":\"/dev/ttyUSB1\",\"baud_rate\":115200,\"enable\":1,\"scan_hz\":10,\"dbscan_eps\":2.0,\"dbscan_min_pts\":4,\"ground_z_thresh\":0.15,\"max_points\":2000,\"max_range_m\":60.0,\"dry_run\":0}"
    },
    {
      "name": "fusion",
      "library_path": "build/lib/libfusion_node.so",
      "auto_start": true,
      "subscribe": [
        "sensor/gps"
      ],
      "publish": [
        {
          "topic": "fusion/localization",
          "type": "Localization",
          "qos": {
            "depth": 1
          }
        },
        {
          "topic": "fusion/latency",
          "type": "LatencyReport"
        }
      ],
      "params": "{\"frequency_hz\":20.0}"
    },
    {
      "name": "planning",
      "library_path": "build/lib/libplanning_node.so",
      "auto_start": true,
      "subscribe": [
        "fusion/localization",
        "perception/obstacles"
      ],
      "publish": [
        {
          "topic": "planning/trajectory",
          "type": "Trajectory",
          "qos": {
            "depth": 1
          }
        }
      ],
      "params": "{\"target_speed\": 8.0, \"max_speed\": 15.0, \"max_accel\": 3.0, \"ref_path_length_m\": 5000.0, \"highway_speed_mps\": 8.0}"
    },
    {
      "name": "control",
      "library_path": "build/lib/libcontrol_node.so",
      "auto_start": true,
      "subscribe": [
        "fusion/localization",
        "planning/trajectory",
        "perception/obstacles"
      ],
      "publish": [
        {
          "topic": "control/raw_cmd",
          "type": "ControlRaw",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 100
          }
        }
      ],
      "params": "{\"pid_kp\": 800.0, \"pid_ki\": 50.0, \"pid_kd\": 100.0, \"target_speed\": 8.0, \"lat_kp\": 0.5, \"lat_kd_heading\": 1.35, \"yaw_damping\": 0.15, \"steer_min_clamp\": 0.016}"
    },
    {
      "name": "safety_control",
      "library_path": "build/lib/libsafety_control_node.so",
      "auto_start": true,
      "subscribe": [
        "control/raw_cmd",
        "perception/obstacles"
      ],
      "publish": [
        {
          "topic": "control/cmd",
          "type": "ControlCmd",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 50
          }
        }
      ],
      "params": "{\"max_throttle\":1.0,\"max_steer\":0.22,\"low_speed_steer\":0.18,\"time_headway\":1.3}"
    },
    {
      "name": "actuator",
      "library_path": "build/lib/libactuator_node.so",
      "auto_start": true,
      "subscribe": [
        "control/cmd"
      ],
      "params": "{\"can_interface\":\"can0\",\"can_throttle_id\":\"0x100\",\"can_steering_id\":\"0x101\",\"can_status_id\":\"0x102\",\"throttle_scale\":1000.0,\"steering_scale\":1000.0,\"bitrate\":500000,\"enable\":1,\"dry_run\":0,\"heartbeat_hz\":10}"
    },
    {
      "name": "inference",
      "library_path": "build/lib/libinference_node.so",
      "auto_start": true,
      "subscribe": [
        "control/cmd",
        "fusion/localization",
        "perception/obstacles",
        "planning/trajectory"
      ],
      "publish": [
        {
          "topic": "inference/trajectory",
          "type": "Trajectory",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        }
      ],
      "params": "{\"max_speed\":15.0,\"frequency_hz\":20.0,\"model_path\":\"tools/train/model.txt\",\"control_mode\":\"shadow\"}"
    },
    {
      "name": "data_recorder",
      "library_path": "build/lib/libdata_recorder_node.so",
      "auto_start": true,
      "subscribe": [
        "fusion/localization",
        "planning/trajectory",
        "perception/obstacles",
        "control/cmd"
      ],
      "params": "{\"frequency_hz\":20.0,\"output_path\":\"/tmp/flow_train_samples.jsonl\"}"
    },
    {
      "name": "learner",
      "library_path": "build/lib/liblearner_node.so",
      "auto_start": true,
      "subscribe": [
        "fusion/localization",
        "planning/trajectory",
        "perception/obstacles",
        "control/cmd"
      ],
      "publish": [
        {
          "topic": "learner/status",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        }
      ],
      "params": "{\"train_hz\":0.5,\"lr\":0.001,\"batch_size\":32,\"buffer_size\":512,\"full_finetune\":0,\"save_interval\":50,\"model_path\":\"tools/train/model.txt\",\"save_path\":\"/tmp/flow_learner_model.txt\"}"
    },
    {
      "name": "model_ota",
      "library_path": "build/lib/libmodel_ota_node.so",
      "auto_start": true,
      "subscribe": [
        "model_ota/cmd",
        "fusion/localization"
      ],
      "publish": [
        { "topic": "model_ota/active", "qos": { "depth": 1, "policy": "drop_oldest", "reliability": "best_effort" } },
        { "topic": "model_ota/status", "qos": { "depth": 1, "policy": "drop_oldest", "reliability": "best_effort" } },
        { "topic": "model_ota/ab_result", "qos": { "depth": 1, "policy": "drop_oldest", "reliability": "best_effort" } }
      ],
      "params": "{\"poll_interval_ms\":500,\"status_hz\":1.0,\"ab_ratio\":0.5,\"runtime_model_path\":\"tools/train/model.txt\",\"registry_path\":\"models/registry.json\"}"
    },
    {
      "name": "monitor",
      "library_path": "build/lib/libmonitor_node.so",
      "auto_start": true,
      "subscribe": [
        "perception/obstacles",
        "fusion/latency",
        "flowengine/node_info",
        "planning/trajectory"
      ],
      "params": "{\"state_file\":\"/tmp/flow_topology.json\",\"export_scene\":true}"
    }
  ]
}
