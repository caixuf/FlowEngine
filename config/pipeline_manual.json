{
  "log_file": "launcher_manual.log",
  "log_level": 2,
  "monitor_interval": 5,
  "enable_monitor": true,
  "scheduler": {
    "mode": "choreo",
    "worker_threads": 0,
    "tick_us": 1000
  },
  "processes": [
    {
      "name": "flowsim",
      "library_path": "build/lib/libflowsim_node.so",
      "auto_start": true,
      "subscribe": [
        "control/cmd"
      ],
      "publish": [
        {
          "topic": "vehicle/state",
          "type": "VehicleState",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 50
          }
        },
        {
          "topic": "road/geometry",
          "type": "RoadGeometry",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        },
        {
          "topic": "road/traffic_lights",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        },
        {
          "topic": "scene/frame",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        },
        {
          "topic": "sim/tick",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        },
        {
          "topic": "sim/collision",
          "qos": {
            "depth": 4,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        }
      ],
      "params": "{\"init_speed\": 5.0, \"target_speed\": 12.0, \"frequency_hz\": 50.0, \"random_seed\": 42, \"scenario_file\": \"scenarios/city_to_highway_full.json\"}"
    },
    {
      "name": "sensor_model",
      "library_path": "build/lib/libsensor_model.so",
      "auto_start": true,
      "subscribe": [
        "vehicle/state"
      ],
      "publish": [
        {
          "topic": "sensor/lidar",
          "type": "LidarFrame",
          "qos": {
            "depth": 2,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 50
          }
        },
        {
          "topic": "sensor/gps",
          "type": "GpsFrame",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 100
          }
        },
        {
          "topic": "sensor/camera",
          "type": "CameraFrame",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort"
          }
        }
      ],
      "params": "{\"lidar_rate_hz\":20,\"lidar_fov_deg\":120.0,\"lidar_max_range_m\":60.0,\"obs_noise_std_m\":0.08,\"enable_simple_occlusion\":1}"
    },
    {
      "name": "perception",
      "library_path": "build/lib/libperception_node.so",
      "auto_start": true,
      "subscribe": [
        "vehicle/state"
      ],
      "publish": [
        {
          "topic": "perception/obstacles",
          "type": "ObstacleList"
        }
      ],
      "params": "{\"frequency_hz\":10.0}"
    },
    {
      "name": "fusion",
      "library_path": "build/lib/libfusion_node.so",
      "auto_start": true,
      "subscribe": [
        "sensor/lidar",
        "sensor/gps"
      ],
      "publish": [
        {
          "topic": "fusion/localization",
          "type": "Localization",
          "qos": {
            "depth": 1
          }
        },
        {
          "topic": "fusion/latency",
          "type": "LatencyReport"
        }
      ],
      "params": "{\"frequency_hz\":20.0}"
    },
    {
      "name": "manual_drive",
      "library_path": "modules/adas_nodes/manual_drive_node.so",
      "auto_start": true,
      "subscribe": [],
      "publish": [
        {
          "topic": "control/cmd",
          "type": "ControlCmd",
          "qos": {
            "depth": 1,
            "policy": "drop_oldest",
            "reliability": "best_effort",
            "deadline_ms": 50
          }
        }
      ],
      "params": "{}"
    },
    {
      "name": "monitor",
      "library_path": "build/lib/libmonitor_node.so",
      "auto_start": true,
      "subscribe": [
        "perception/obstacles",
        "vehicle/state",
        "fusion/latency",
        "flowengine/node_info",
        "road/geometry",
        "scene/frame"
      ],
      "params": "{\"state_file\":\"/tmp/flow_topology.json\",\"export_scene\":true}"
    }
  ]
}
