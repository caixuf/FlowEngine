{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/caixuf/FlowEngine/tools/schema/flowboard.schema.json",
  "title": "FlowBoard Dashboard Payload",
  "description": "Single source of truth for the FlowBoard visualization data contract. Describes both the on-disk state file (/tmp/flow_topology.json written by monitor_node.c) and the normalized /api/topology response served by flowboard_server.py. The schema is intentionally permissive (additionalProperties allowed) so producers may add fields without breaking consumers; only the fields the dashboard actually relies on are constrained here.",
  "type": "object",
  "properties": {
    "self": {
      "type": "string",
      "description": "Name of the launcher/host process that produced this snapshot."
    },
    "source": {
      "type": "string",
      "enum": ["live", "stale", "demo"],
      "description": "Freshness/origin of the data. 'live' = fresh data from a running pipeline; 'stale' = server reachable but producer has not refreshed within STALE_AFTER_SEC (last real data is retained); 'demo' = built-in simulated data (no real pipeline)."
    },
    "stale": {
      "type": "boolean",
      "description": "True when source == 'stale'. Convenience mirror of source for the frontend."
    },
    "age_sec": {
      "type": "number",
      "description": "Seconds since the state file was last successfully read (live/stale only)."
    },
    "timestamp": {
      "type": "number",
      "description": "Unix epoch seconds when this snapshot was produced."
    },
    "nodes": {
      "type": "array",
      "description": "Pipeline nodes/tasks and the topics they publish/subscribe.",
      "items": { "$ref": "#/definitions/node" }
    },
    "metrics": { "$ref": "#/definitions/metrics" },
    "endpoints": {
      "type": "array",
      "description": "Flattened (node, topic, role) tuples derived by the server for the topic table.",
      "items": { "$ref": "#/definitions/endpoint" }
    },
    "topic_roles": {
      "type": "array",
      "description": "Per-topic publisher/subscriber lists derived by the server for the topology graph.",
      "items": { "$ref": "#/definitions/topicRole" }
    },
    "registry": {
      "type": "object",
      "description": "Optional flow_registry export (tasks/topics) used to synthesize nodes when discovery nodes are absent."
    },
    "scene": {
      "type": "object",
      "description": "Optional 3D scene state (ego pose, obstacles, lidar) for the WebGL/2D renderer."
    }
  },
  "definitions": {
    "node": {
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "pid": { "type": "integer" },
        "alive": { "type": "boolean" },
        "caps": { "type": "integer", "description": "Bitmask: bit0=pub, bit1=sub." },
        "kind": { "type": "string" },
        "description": { "type": "string" },
        "plugin": { "type": "string" },
        "topics": {
          "type": "array",
          "items": { "$ref": "#/definitions/topic" }
        },
        "inputs": { "type": "array", "items": { "type": "string" } },
        "outputs": { "type": "array", "items": { "type": "string" } }
      },
      "additionalProperties": true
    },
    "topic": {
      "type": "object",
      "properties": {
        "topic": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["pub", "sub", "pubsub", "unknown"] },
        "caps": { "type": "integer" },
        "type_id": { "type": "string" },
        "freq": { "type": "number" }
      },
      "additionalProperties": true
    },
    "metrics": {
      "type": "object",
      "properties": {
        "bus": {
          "type": "object",
          "properties": {
            "published": { "type": "number" },
            "delivered": { "type": "number" },
            "dropped": { "type": "number" }
          },
          "additionalProperties": true
        },
        "latency": {
          "type": "object",
          "properties": {
            "avg_us": { "type": "number" },
            "p50_us": { "type": "number" },
            "p99_us": { "type": "number" }
          },
          "additionalProperties": true
        },
        "transport": { "type": "object" },
        "scheduler": { "type": "object" },
        "vehicle": { "$ref": "#/definitions/vehicle" },
        "sysmon": { "$ref": "#/definitions/sysmon" },
        "topics": { "type": "array" }
      },
      "additionalProperties": true
    },
    "vehicle": {
      "type": "object",
      "properties": {
        "speed": { "type": "number" },
        "target_speed": { "type": "number" },
        "throttle": { "type": "number" },
        "brake": { "type": "number" },
        "x": { "type": "number" },
        "y": { "type": "number" },
        "error": { "type": "number" }
      },
      "additionalProperties": true
    },
    "sysmon": {
      "type": "object",
      "properties": {
        "cpu_total_pct": { "type": "number" },
        "mem_used_pct": { "type": "number" },
        "mem_used_kb": { "type": "number" },
        "mem_total_kb": { "type": "number" },
        "proc_rss_kb": { "type": "number" },
        "cpu_count": { "type": "integer" },
        "load1": { "type": "number" },
        "load5": { "type": "number" },
        "load15": { "type": "number" },
        "thread_count": { "type": "integer" },
        "threads": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "tid": { "type": "integer" },
              "name": { "type": "string" },
              "cpu_pct": { "type": "number" },
              "state": { "type": "string" }
            },
            "additionalProperties": true
          }
        }
      },
      "additionalProperties": true
    },
    "endpoint": {
      "type": "object",
      "properties": {
        "node": { "type": "string" },
        "topic": { "type": "string" },
        "role": { "type": "string", "enum": ["pub", "sub", "pubsub", "unknown"] },
        "type_id": { "type": "string" },
        "freq": { "type": "number" }
      },
      "required": ["node", "topic", "role"],
      "additionalProperties": true
    },
    "topicRole": {
      "type": "object",
      "properties": {
        "topic": { "type": "string" },
        "publishers": { "type": "array", "items": { "type": "string" } },
        "subscribers": { "type": "array", "items": { "type": "string" } }
      },
      "required": ["topic"],
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
