prefix=@CMAKE_INSTALL_PREFIX@
exec_prefix=${prefix}
libdir=${exec_prefix}/lib
includedir=${prefix}/include/flowengine

Name: FlowEngine
Description: Lightweight middleware for autonomous driving & robotics
Version: @PROJECT_VERSION@
Requires: libcjson
Libs: -L${libdir} -lflowengine_core -lpthread -ldl -lrt
Cflags: -I${includedir} -D_GNU_SOURCE
